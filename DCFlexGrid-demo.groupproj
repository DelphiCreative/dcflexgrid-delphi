    </Target>
    <Target Name="Clean">
        <CallTarget Targets="DCFlexGridD:Clean;DCFlexGridR:Clean;Demo_DCFlexGrid:Clean"/>
    </Target>
    <Target Name="Make">
        <CallTarget Targets="DCFlexGridD:Make;DCFlexGridR:Make;Demo_DCFlexGrid:Make"/>
    </Target>
    <Import Project="$(BDS)\Bin\CodeGear.Group.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Group.Targets')"/>
