    </Target>
    <Target Name="Demo_DCFlexGrid:Clean">
        <MSBuild Projects="demo\Demo.DCFlexGrid.dproj" Targets="Clean"/>
    </Target>
    <Target Name="Demo_DCFlexGrid:Make">
        <MSBuild Projects="demo\Demo.DCFlexGrid.dproj" Targets="Make"/>
